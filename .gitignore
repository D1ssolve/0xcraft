# Dependencies
.omo/*
!.omo/rules/
!.omo/rules/**
.sisyphus/*
!.sisyphus/rules/
!.sisyphus/rules/**
node_modules/

# Build output
# Includes generated Claude Code plugin output:
# dist/claude-code-plugin/0xcraft/ is ephemeral and recreated by `0xcraft claude-code generate`.
dist/

# Platform binaries (built, not committed)
packages/*/bin/oh-my-opencode
packages/*/bin/oh-my-opencode.exe
packages/*/bin/*.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Lock files (use bun.lockb instead)
package-lock.json
yarn.lock

# Environment
.env
.env.local
test-injection/
notepad.md
oauth-success.html
*.bun-build
.omx/
.dori-sync/
.dori/
.playwright-mcp/

# Debugging / session artifacts (skill workspace residue)
.debugging
.debug-journal*.md
session-ses_*.md
plans/

# Generated harness artifacts — recreated by
# `0xcraft {claude-code,codex} generate` / `install --harness ...`.
# Never commit:
#   - .claude-plugin/                    claude-code filesystem plugin output
#   - .codex/                            codex filesystem tree (config.toml, agents/, hooks/, skills/)
#   - .codex-plugin/                     codex filesystem plugin bundle (Batch E)
#   - .agents/skills/                    codex skills tree (copies of skills/<id>/SKILL.md)
#   - .agents/plugins/marketplace.json   codex marketplace stub
.claude-plugin/
.codex/
.codex-plugin/
.agents/skills/
.agents/plugins/marketplace.json

# Dual-mode planning artifacts (spec-driven-dual / system-architect-dual).
# The synthesized canonical files (.ai/spec.md, .ai/adr.md, .ai/tasks.md)
# remain tracked; per-model candidates and compare reports are local only.
.ai/*.gpt.md
.ai/*.sonnet.md
.ai/spec.compare.md
.ai/arch.compare.md
